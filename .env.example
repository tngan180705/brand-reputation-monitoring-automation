# --- API Keys cho Crawling ---
TWITTER_API_KEY=your_key_here
FACEBOOK_ACCESS_TOKEN=your_token_here
NEWS_API_KEY=your_news_api_key

# --- Database (Docker) ---
# Dùng localhost nếu chạy app bên ngoài Docker, dùng 'mongodb' nếu chạy trong Docker network
MONGO_URI=mongodb://localhost:27017/highlands_db
DB_NAME=highlands_db
COLLECTION_NAME=mentions

# --- n8n Config ---
N8N_PORT=5678
N8N_ENCRYPTION_KEY=random_string_for_security

# --- Backend Python ---
FLASK_ENV=development
PYTHONPATH=./src

# --- Google Sheets Config ---
GOOGLE_SHEET_ID=1mBM7ejhLQ1ByfotXxsM4rY5Wdbjn0q8eY3n73yOb0Gs
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email
GOOGLE_PRIVATE_KEY="your_private_key_here"